{
  "$schema": "../packages/llm-catalog-core/src/llm_catalog/core/schema.json",
  "providers": [
    {
      "id": "anthropic",
      "models": [
        {
          "id": "claude-sonnet-5",
          "settings": {
            "temperature": 1
          }
        }
      ]
    },
    {
      "id": "fireworks",
      "vendor": {
        "id": "openai-compatible",
        "baseURL": "https://api.fireworks.example.invalid/inference/v1",
        "apiKey": {
          "envVarName": "FIREWORKS_API_KEY"
        },
        "name": "fireworks"
      },
      "models": [
        {
          "id": "accounts/fireworks/models/gpt-oss-120b"
        }
      ]
    },
    {
      "id": "examplegw",
      "gateway": {
        "baseURL": "https://gateway.example.invalid/base",
        "apiKey": {
          "envVarName": "EXAMPLEGW_API_KEY"
        },
        "headers": {
          "Authorization": "Bearer {apiKey}"
        },
        "query": {
          "api-version": "2026-01-01"
        },
        "backends": {
          "claude": {
            "vendor": "anthropic",
            "pathTemplate": "anthropic/{slug}"
          },
          "gpt": {
            "vendor": "openai",
            "pathTemplate": "gpt/{slug}"
          },
          "gemini": {
            "vendor": "google",
            "pathTemplate": "gemini/{slug}:{action}",
            "actionMap": {
              "streamGenerateContent": "customStreamGenerateContent"
            }
          }
        }
      },
      "settings": {
        "temperature": 0
      },
      "models": [
        {
          "id": "light-anthropic",
          "backend": "claude",
          "capabilities": {
            "structuredOutput": "tool"
          }
        },
        {
          "id": "light-openai",
          "backend": "gpt",
          "slug": "oai-light",
          "api": "chat"
        },
        {
          "id": "search-google",
          "backend": "gemini",
          "capabilities": {
            "multiStepTools": false,
            "grounding": ["web_search", "url_context", "code_execution"]
          }
        }
      ]
    }
  ],
  "roles": {
    "chat": "anthropic:claude-sonnet-5",
    "bulk": "fireworks:accounts/fireworks/models/gpt-oss-120b",
    "fast": { "provider": "examplegw", "model": "light-openai" },
    "reasoning": "examplegw:light-anthropic",
    "search": "examplegw:search-google"
  }
}
